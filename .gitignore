# ---------------------------------------------------------------------------
# Build artifacts (CMake / Go temp output, never committed)
# ---------------------------------------------------------------------------
client/build/
server/server
server/server.exe
tools/build/
tools/gue/build/
tools/terrain-editor/build/

# ---------------------------------------------------------------------------
# Distributable runtime tree
# Binaries land here after build. Assets, scripts, shaders, DB live here as
# source-of-truth — what we ship is dist/client/.
# Ignore only the binary artifacts and the database (which is regenerated).
# ---------------------------------------------------------------------------
dist/**/*.exe
dist/**/*.dll
dist/**/*.pdb
dist/server/rco.db
dist/server/rco.db-shm
dist/server/rco.db-wal

# ---------------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------------
server/vendor/
*.test

# ---------------------------------------------------------------------------
# C++ / CMake
# ---------------------------------------------------------------------------
*.o
*.obj
*.pdb
*.ilk
*.exp
*.lib
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

# Executables (keep intentionally committed ones by adding ! exceptions below)
*.exe

# ---------------------------------------------------------------------------
# Assets (large binary files — store in Git LFS or a separate asset server)
# ---------------------------------------------------------------------------
client/assets/models/
client/assets/textures/
client/assets/audio/

# Compressed GPU textures
*.ktx2

# 3D model formats
*.fbx
# Allow sample/test .glb files; ignore bulk game assets
*.glb
!client/assets/samples/**/*.glb

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.sql.bak
*.dump
# SQLite runtime file — generated automatically, never commit
server/rco.db
server/*.db
dist/server/rco.db
dist/server/*.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
Data/Logs/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.user
*.suo
.vs/

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# TLS certificates (generated at runtime by the server)
# ---------------------------------------------------------------------------
*.pem
*.crt
*.key

# ---------------------------------------------------------------------------
# Go module files
# go.sum IS committed; vendor directory is NOT.
# ---------------------------------------------------------------------------
!server/go.sum

# ---------------------------------------------------------------------------
# Lua bytecode
# ---------------------------------------------------------------------------
*.luac

# ---------------------------------------------------------------------------
# Unreal Engine generated files (plugin-only tree — the host .uproject lives
# outside this repo; see unreal/README.md for the dev workflow)
# ---------------------------------------------------------------------------
unreal/Plugins/*/Binaries/
unreal/Plugins/*/Intermediate/
unreal/**/*.sln
unreal/**/*.vcxproj*
