# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
client/build/
server/server
server/server.exe
tools/build/

# ---------------------------------------------------------------------------
# Go
# ---------------------------------------------------------------------------
server/vendor/
*.test

# ---------------------------------------------------------------------------
# C++ / CMake
# ---------------------------------------------------------------------------
*.o
*.obj
*.pdb
*.ilk
*.exp
*.lib
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

# Executables (keep intentionally committed ones by adding ! exceptions below)
*.exe

# ---------------------------------------------------------------------------
# Assets (large binary files — store in Git LFS or a separate asset server)
# ---------------------------------------------------------------------------
client/assets/models/
client/assets/textures/
client/assets/audio/

# Compressed GPU textures
*.ktx2

# 3D model formats
*.fbx
# Allow sample/test .glb files; ignore bulk game assets
*.glb
!client/assets/samples/**/*.glb

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.sql.bak
*.dump
# SQLite runtime file — generated automatically, never commit
server/rco.db
server/*.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
Data/Logs/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.user
*.suo
.vs/

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# TLS certificates (generated at runtime by the server)
# ---------------------------------------------------------------------------
*.pem
*.crt
*.key

# ---------------------------------------------------------------------------
# Go module files
# go.sum IS committed; vendor directory is NOT.
# ---------------------------------------------------------------------------
!server/go.sum

# ---------------------------------------------------------------------------
# Lua bytecode
# ---------------------------------------------------------------------------
*.luac
